PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/cep
JWT_SECRET=change_this_to_a_long_random_string

# Customers enter THEIR OWN @gmail.com on the signup form.
# OTP is delivered TO that address. You only configure the SENDER below.

# ── Option A: SendGrid (easiest — free tier) ──
# 1. https://sendgrid.com → sign up → Settings → Sender Authentication → verify your email
# 2. Settings → API Keys → create key (starts with SG.)
SENDGRID_API_KEY=
SENDGRID_FROM=dipuyadav4152@gmail.com

# ── Option B: Gmail SMTP ──
# App Password only (16 letters, no @): https://myaccount.google.com/apppasswords
GMAIL_USER=dipuyadav4152@gmail.com
GMAIL_APP_PASSWORD=

# ── Option C: EmailJS ──
EMAILJS_SERVICE_ID=
EMAILJS_TEMPLATE_ID=
EMAILJS_PUBLIC_KEY=
EMAILJS_PRIVATE_KEY=

FRONTEND_URL=http://127.0.0.1:5500
